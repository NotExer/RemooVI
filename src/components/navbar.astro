---
import icon from "../assets/ConverterIcon.png";
---

<nav
  class="fixed top-0 z-50 w-full border-b border-white/10 bg-black/80 backdrop-blur-xl"
>
  <div class="flex items-center justify-between mx-auto px-6 py-4 max-w-6xl">
    <a href="/" class="flex items-center space-x-3 group">
      <img
        src={icon.src}
        alt="RemooVI"
        class="h-8 w-8 transition-transform duration-300 group-hover:scale-105"
      />
      <span class="text-xl font-semibold text-[#f5f5f7] tracking-tight">
        RemooVI
      </span>
    </a>

    <ul class="hidden md:flex space-x-8">
      <li>
        <a
          href="#hero"
          class="text-sm font-medium text-[#a1a1a6] hover:text-[#f5f5f7] transition-colors"
        >
          Inicio
        </a>
      </li>
      <li>
        <a
          href="#how-it-works"
          class="text-sm font-medium text-[#a1a1a6] hover:text-[#f5f5f7] transition-colors"
        >
          Como funciona
        </a>
      </li>
      <li>
        <a
          href="#features"
          class="text-sm font-medium text-[#a1a1a6] hover:text-[#f5f5f7] transition-colors"
        >
          Caracteristicas
        </a>
      </li>
    </ul>

    <div class="md:hidden">
      <button
        id="burger"
        class="flex flex-col justify-between w-6 h-4 focus:outline-none"
      >
        <span
          class="burger-line top-line block h-[2px] bg-[#f5f5f7] w-full rounded transition-all duration-300 ease-in-out"
        ></span>
        <span
          class="burger-line bottom-line block h-[2px] bg-[#f5f5f7] w-full rounded transition-all duration-300 ease-in-out"
        ></span>
      </button>
    </div>
  </div>
</nav>
<ul
  id="mobileMenu"
  class="fixed z-40 top-[65px] left-0 w-full bg-black/95 backdrop-blur-xl border-b border-white/10 transition-all duration-300 ease-in-out md:hidden overflow-hidden max-h-0"
>
  <li class="py-4 border-b border-[#38383a]">
    <a
      href="#hero"
      class="block text-center text-base font-medium text-[#f5f5f7] hover:text-[#0a84ff] transition-colors"
    >
      Inicio
    </a>
  </li>
  <li class="py-4 border-b border-[#38383a]">
    <a
      href="#how-it-works"
      class="block text-center text-base font-medium text-[#f5f5f7] hover:text-[#0a84ff] transition-colors"
    >
      Como funciona
    </a>
  </li>
  <li class="py-4">
    <a
      href="#features"
      class="block text-center text-base font-medium text-[#f5f5f7] hover:text-[#0a84ff] transition-colors"
    >
      Caracteristicas
    </a>
  </li>
</ul>

<script type="text/javascript">
  document.getElementById("burger").addEventListener("click", () => {
    const menu = document.getElementById("mobileMenu");
    const topLine = document.querySelector(".top-line");
    const bottomLine = document.querySelector(".bottom-line");

    menu.classList.toggle("max-h-0");
    menu.classList.toggle("max-h-96");

    topLine.classList.toggle("rotate-45");
    topLine.classList.toggle("translate-y-[7px]");

    bottomLine.classList.toggle("-rotate-45");
    bottomLine.classList.toggle("-translate-y-[7px]");
  });
</script>
